    -- GALAXY
    -- =========================================
    local galaxyVF  = nil
    local galaxyAtt = nil
    local galaxyOn  = false
    local lastHop   = 0
    local origJP    = 50
    local origWG    = 196.2

    local function capJP()
        local c = Player.Character
        if c then
            local hm = c:FindFirstChildOfClass("Humanoid")
            if hm and hm.JumpPower > 0 then origJP = hm.JumpPower end
        end
    end
    local function capWG()
        pcall(function() if workspace.Gravity then origWG = workspace.Gravity end end)
    end

    task.spawn(function() task.wait(0.5); capJP(); capWG() end)
    Player.CharacterAdded:Connect(function() task.wait(0.5); capJP(); capWG() end)

    local function setupGP()
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h then return end
            if galaxyVF  then galaxyVF:Destroy() end
            if galaxyAtt then galaxyAtt:Destroy() end
            galaxyAtt = Instance.new("Attachment")
            galaxyAtt.Parent = h
            galaxyVF = Instance.new("VectorForce")
            galaxyVF.Attachment0       = galaxyAtt
            galaxyVF.ApplyAtCenterOfMass = true
            galaxyVF.RelativeTo        = Enum.ActuatorRelativeTo.World
            galaxyVF.Force             = Vector3.zero
            galaxyVF.Parent            = h
        end)
        pcall(function()
            local c = Player.Character
            if c then
                local hm = c:FindFirstChildOfClass("Humanoid")
                if hm then
                    local gp = Values.GalaxyGravity / 100
                    local tg = origWG * gp
                    hm.JumpPower = origJP * math.sqrt(tg / origWG)
                end
            end
        end)
    end

    local function startGalaxy()
        if galaxyOn then return end
        galaxyOn = true
        setupGP()
        if not Connections.galaxy then
            Connections.galaxy = RunService.Heartbeat:Connect(function()
                if not galaxyOn then return end
                pcall(function()
                    local c = Player.Character
                    if not c then return end
                    local h  = c:FindFirstChild("HumanoidRootPart")
                    local hm = c:FindFirstChildOfClass("Humanoid")
                    if h and hm then
                        local st = hm:GetState()
                        if st == Enum.HumanoidStateType.Freefall or st == Enum.HumanoidStateType.Jumping then
                            local hd = 0.08
                            if tick() - lastHop > hd then
                                lastHop = tick()
                                h.AssemblyLinearVelocity = Vector3.new(
                                    h.AssemblyLinearVelocity.X,
                                    Values.HopPower,
                                    h.AssemblyLinearVelocity.Z
                                )
                            end
                        end
                    end
                end)
                if galaxyVF and galaxyOn then
                    pcall(function()
                        local c = Player.Character
                        if not c then return end
                        local mass = 0
                        for _, p in c:GetDescendants() do
                            if p:IsA("BasePart") then mass = mass + p:GetMass() end
                        end
                        local tg = origWG * (Values.GalaxyGravity / 100)
                        galaxyVF.Force = Vector3.new(0, mass * (origWG - tg) * 0.95, 0)
                    end)
                end
            end)
        end
    end

    local function stopGalaxy()
        galaxyOn  = false
        spaceHeld = false
        if Connections.galaxy then Connections.galaxy:Disconnect(); Connections.galaxy = nil end
        if galaxyVF  then galaxyVF:Destroy();  galaxyVF  = nil end
        if galaxyAtt then galaxyAtt:Destroy(); galaxyAtt = nil end
        pcall(function()
            local c = Player.Character
            if c then
                local hm = c:FindFirstChildOfClass("Humanoid")
                if hm then hm.JumpPower = origJP end
            end
        end)
    end

