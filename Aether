-- KEY SYSTEM
-- ============================================
local KeySystem = {
    IsValid = false,
    IsOwner = false,
    IsFree  = false,
    VerifiedUsers = {},
}

function KeySystem:FetchKeys()
    local ok, res = pcall(function()
        return game:HttpGet(self.Config.KeysURL)
    end)
    if not ok or not res then
        warn("[Aether] Failed to fetch keys")
        return {}
    end
    local tbl = {}
    for line in string.gmatch(res, "[^\r\n]+") do
        local key, uid = string.match(line, "{(.-)},{(.-)}")
        if key and uid then
            key = string.upper(string.gsub(key, "%s+", ""))
            uid = string.gsub(uid, "%s+", "")
            tbl[key] = uid
        end
    end
    return tbl
end

function KeySystem:IsExpired(data)
    return data.expire and os.time() > data.expire
end

function KeySystem:VerifyKey(inputKey)
    inputKey = inputKey and string.upper(string.match(inputKey, "^%s*(.-)%s*$")) or ""
    if #inputKey == 0 then return false, "المفتاح فارغ!", "normal" end
    if #inputKey > self.Config.MaxKeyLength then return false, "الحد الأقصى 24 حرف!", "normal" end

    local userId = tostring(Player.UserId)
    local current = self.VerifiedUsers[userId]
    if current and not self:IsExpired(current) then
        return true, "مفعّل مسبقاً!", self.IsOwner and "owner" or "normal"
    end

    -- Owner Key
    if inputKey == string.upper(self.Config.OwnerKey) then
        if userId ~= tostring(self.Config.OwnerUserId) then
            return false, "Owner فقط!", "normal"
        end
        self.IsOwner = true
        self.IsValid = true
        self.VerifiedUsers[userId] = { key = inputKey, expire = math.huge }
        return true, "Owner مُفعَّل!", "owner"
    end

    -- Free Key
    if self.Config.FreeKeyEnabled and inputKey == string.upper(self.Config.FreeKey) then
        self.IsValid = true
        self.IsFree  = true
        self.VerifiedUsers[userId] = { key = inputKey, expire = math.huge }
        return true, "مفتاح مجاني!", "free"
    end

    -- Normal Keys
    local keys = self:FetchKeys()
    local validUid = keys[inputKey]
    if not validUid then return false, "مفتاح غير صحيح!", "normal" end
    if tostring(validUid) ~= userId then return false, "ليس مفتاحك!", "normal" end

    self.IsValid = true
    self.VerifiedUsers[userId] = { key = inputKey, expire = math.huge }
    return true, "تم التفعيل!", "normal"
end

function KeySystem:IsUserVerified()
    local data = self.VerifiedUsers[tostring(Player.UserId)]
    if not data then return false end
    if self:IsExpired(data) then
        self.VerifiedUsers[tostring(Player.UserId)] = nil
        return false
    end
    return true
end

