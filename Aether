    local function runWaypoints(wpList, idRef, idKey, threadKey, enabledKey)
        idRef[idKey] = idRef[idKey] + 1
        local myId   = idRef[idKey]
        idRef[threadKey] = task.spawn(function()
            for _, wpd in ipairs(wpList) do
                if myId ~= idRef[idKey] then break end
                local wp   = wpd[1]
                local mode = wpd[2]
                while myId == idRef[idKey] do
                    local c = Player.Character
                    if not c then break end
                    local h = c:FindFirstChild("HumanoidRootPart")
                    if not h then break end
                    local dXZ = Vector3.new(wp.X - h.Position.X, 0, wp.Z - h.Position.Z)
                    if dXZ.Magnitude < 0.5 then
                        h.CFrame = CFrame.new(wp.X, h.Position.Y, wp.Z)
                        break
                    end
                    local md  = dXZ.Unit
                    local hm  = c:FindFirstChildOfClass("Humanoid")
                    if hm then hm:Move(md, false) end
                    local sp  = (mode == 1) and Values.BoostSpeed or Values.StealSpeed
                    h.AssemblyLinearVelocity = Vector3.new(md.X * sp, h.AssemblyLinearVelocity.Y, md.Z * sp)
                    task.wait()
                end
                if myId ~= idRef[idKey] then break end
            end
            if myId == idRef[idKey] then
                resetVel()
                CurrentMode = "None"
                Enabled[enabledKey] = false
                if VisualSetters[enabledKey] then VisualSetters[enabledKey](false, true) end
            end
        end)
    end

    local wpState = { autoLeftId = 0, autoRightId = 0, autoLeftThread = nil, autoRightThread = nil }

    local function startAL()
        runWaypoints(LWP, wpState, "autoLeftId", "autoLeftThread", "AutoLeft")
