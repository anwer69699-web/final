function startMainScript(scriptVersion)
    print("[Aether V4] Starting | Version:", scriptVersion)

    -- CLEANUP SOUNDS
    local function removeCharSounds(char)
        if not char then return end
        pcall(function()
            for _, obj in pairs(char:GetDescendants()) do
                if obj:IsA("Sound") then
                    obj.SoundId = ""
                    obj.Volume  = 0
                    obj:Destroy()
                elseif obj:IsA("SoundEffect") or obj:IsA("ReverbSoundEffect") or obj:IsA("DistortionSoundEffect") then
                    obj:Destroy()
                end
            end
        end)
        pcall(function()
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                for _, obj in pairs(hum:GetChildren()) do
                    if obj:IsA("Sound") or obj:IsA("SoundEffect") then obj:Destroy() end
                end
            end
        end)
    end

    -- DEEP CLEAN
    do
        local function deepClean(p, attr)
            if not p then return end
            pcall(function()
                for _, c in ipairs(p:GetChildren()) do
