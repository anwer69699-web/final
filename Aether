    local function execDrop()
        if dropFiring then return end
        dropFiring = true
        local cc = RunService.Stepped:Connect(function()
            for _, p in Players:GetPlayers() do
                if p ~= Player and p.Character then
                    for _, a in p.Character:GetChildren() do
                        if a:IsA("BasePart") then a.CanCollide = false end
                    end
                end
            end
        end)
        table.insert(dropConns, cc)
        task.spawn(function()
            for att = 1, 3 do
                if not dropFiring then break end
                for _ = 1, 8 do
                    if not dropFiring then break end
                    pcall(function()
                        local c = Player.Character
                        if not c then return end
                        local hrp = c:FindFirstChild("HumanoidRootPart")
                        if not hrp then return end
                        local vel = hrp.AssemblyLinearVelocity
                        hrp.AssemblyLinearVelocity = Vector3.new(vel.X * 3000, vel.Y + 3000, vel.Z * 3000)
                        RunService.RenderStepped:Wait()
                        if hrp and hrp.Parent then hrp.AssemblyLinearVelocity = vel end
                    end)
                    task.wait(0.005)
                end
                task.wait(0.001)
            end
            task.wait(0.001)
            for _, cv in ipairs(dropConns) do pcall(function() cv:Disconnect() end) end
            table.clear(dropConns)
            dropFiring = false
            Enabled.Drop = false
            if VisualSetters.Drop then VisualSetters.Drop(false, true) end
        end)
    end

    local function stopDrop()
        for _, cv in ipairs(dropConns) do pcall(function() cv:Disconnect() end) end
        table.clear(dropConns)
        dropFiring = false
    end

    local function execTPD()
        if tpDownFiring then return end
        tpDownFiring = true
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if h then h.CFrame = CFrame.new(h.Position.X, -7.30, h.Position.Z) end
        end)
        task.wait(0.3)
        tpDownFiring = false
        Enabled.TPDown = false
        if VisualSetters.TPDown then VisualSetters.TPDown(false, true) end
    end

