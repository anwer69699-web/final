    -- =========================================
    -- LOCK TARGET (IMPROVED)
    -- =========================================
    local function fNP(mHRP)
        local n = nil; local nd = math.huge
        for _, p in Players:GetPlayers() do
            if p ~= Player and p.Character then
                local eh  = p.Character:FindFirstChild("HumanoidRootPart")
                local hm  = p.Character:FindFirstChildOfClass("Humanoid")
                if eh and hm and hm.Health > 0 then
                    local d = (eh.Position - mHRP.Position).Magnitude
                    if d < nd then nd = d; n = eh end
                end
            end
        end
        return n, nd
    end

    local function startL()
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        if lockBAV then lockBAV:Destroy(); lockBAV = nil end
        lockBAV = Instance.new("BodyAngularVelocity")
        lockBAV.Name           = "LockBAV"
        lockBAV.MaxTorque      = Vector3.new(0, math.huge, 0)
        lockBAV.AngularVelocity = Vector3.zero
        lockBAV.Parent         = h
        tag(lockBAV)

        if Connections.lock then return end
        Connections.lock = RunService.Heartbeat:Connect(function()
            if not Enabled.Lock or CurrentMode ~= "Lock" then return end
            pcall(function()
                local ch = Player.Character
                if not ch then return end
                local hroot = ch:FindFirstChild("HumanoidRootPart")
                if not hroot or not lockBAV or not lockBAV.Parent then return end

                local tg, dist = fNP(hroot)
                if not tg then lockBAV.AngularVelocity = Vector3.zero; return end

                local dd  = 4
                local flat = Vector3.new(tg.Position.X - hroot.Position.X, 0, tg.Position.Z - hroot.Position.Z)
                local flatMag = flat.Magnitude

                -- Movement toward/away from target
                local mv = Vector3.zero
                if flatMag > 0.001 then
                    local dir = flat.Unit
                    if flatMag > dd + 0.1 then
                        mv = dir * Values.LockSpeed
                    elseif flatMag < dd - 0.1 then
                        mv = -dir * Values.LockSpeed
                    end
                end

                -- Vertical adjustment
                local ye = tg.Position.Y - hroot.Position.Y
                local yv = 0
                if math.abs(ye) > 0.5 then
                    yv = math.clamp(ye * 4, -60, 60)
                end

                -- IMPROVED: smooth rotation using cross product only on Y axis
                local look = hroot.CFrame.LookVector
                local td   = flatMag > 0.001 and flat.Unit or look
                local dot  = math.clamp(look:Dot(td), -1, 1)
                if dot < 0.999 then
                    local cr = look:Cross(td)
                    local mg = cr.Magnitude
                    if mg > 0.001 then
                        local spinSpeed = math.clamp(flatMag * 0.4, 10, 30)
                        lockBAV.AngularVelocity = Vector3.new(0, (cr / mg).Y * spinSpeed, 0)
                    end
                else
                    lockBAV.AngularVelocity = Vector3.zero
                end

                hroot.AssemblyLinearVelocity = Vector3.new(mv.X, yv, mv.Z)
            end)
        end)
    end

    local function stopL()
        if Connections.lock then Connections.lock:Disconnect(); Connections.lock = nil end
        if lockBAV then lockBAV:Destroy(); lockBAV = nil end
        local c = Player.Character
        if c then
            local h = c:FindFirstChild("HumanoidRootPart")
            if h then
                for _, v in pairs(h:GetChildren()) do
                    if v.Name == "LockBAV" then v:Destroy() end
                end
            end
        end
        if CurrentMode == "Lock" then CurrentMode = "None" end
        resetVel()
    end

